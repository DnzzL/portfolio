---
import config from '@config/config.json';
const year = new Date().getFullYear();
---

<footer class="border-t border-[rgba(255,255,255,0.06)] print:hidden">
  <div class="mx-auto max-w-6xl px-6 py-12 sm:px-8 sm:py-16 lg:px-12">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-[#4a5568]">
        <span class="text-[#718096]">$</span> echo "&copy; {year} {config.site.title}"
      </p>
      <p class="text-xs text-[#4a5568]">
        Nice, France
      </p>
    </div>
  </div>
</footer>
