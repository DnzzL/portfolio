---
import { Image } from "astro:assets";
import config from "@config/config.json";
import social from "@config/social";

const socialItems = social.networks;
---

<section class="relative bg-surface print:hidden overflow-hidden">
  <div class="absolute inset-0 bg-[url('data:image/svg+xml,%3Csvg width="60" height="60" viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg"%3E%3Cg fill="none" fill-rule="evenodd"%3E%3Cg fill="%23E3B2B3" fill-opacity="0.02"%3E%3Cpath d="M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z"/%3E%3C/g%3E%3C/g%3E%3C/svg%3E')] opacity-30"></div>
  
  <div class="relative mx-auto max-w-7xl px-6 py-32 sm:px-8 sm:py-40 lg:px-12 lg:py-48">
    <div class="text-center">
      <div class="animate-fade-in">
        <h1 class="text-5xl font-bold tracking-tight text-loud sm:text-6xl lg:text-7xl xl:text-8xl">
          Thomas Legrand
        </h1>
      </div>
      
      <div class="mt-8 animate-fade-in-up" style="animation-delay: 0.2s">
        <p class="text-xl leading-8 text-text max-w-3xl mx-auto lg:text-2xl">
          Building elegant solutions to complex problems. 
          <span class="block mt-2 text-accent-jade font-medium">
            Software engineer • Open source contributor • Technology enthusiast
          </span>
        </p>
      </div>
      
      <div class="mt-12 flex flex-col sm:flex-row items-center justify-center gap-x-6 gap-y-4 animate-fade-in-up" style="animation-delay: 0.4s">
        <a href="/blog" class="inline-flex items-center justify-center rounded-xl bg-primary-600 px-8 py-4 text-base font-semibold text-surface shadow-soft hover:shadow-medium hover:bg-primary-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-600 transition-all duration-300 hover:scale-105">
          View my work
        </a>
        <a href="/resume" class="group inline-flex items-center text-base font-semibold leading-6 text-text hover:text-primary-400 transition-colors duration-300">
          Resume 
          <span class="ml-2 transform transition-transform duration-300 group-hover:translate-x-1" aria-hidden="true">→</span>
        </a>
      </div>
      
      <div class="mt-16 flex items-center justify-center gap-x-8 animate-fade-in" style="animation-delay: 0.6s">
        {
          socialItems?.map((item, index) => (
            <a 
              href={item.url} 
              target="_blank" 
              rel="noopener noreferrer" 
              class="group relative text-text-muted hover:text-primary-400 transition-all duration-300 hover:scale-110"
              style={`animation-delay: ${0.8 + index * 0.1}s`}
            >
              <figure class="w-6 h-6">
                <Fragment set:html={item.svg} />
              </figure>
              <div class="absolute -inset-2 rounded-full bg-primary-600/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            </a>
          ))
        }
      </div>
    </div>
  </div>
  
  <div class="absolute bottom-0 left-0 right-0 h-px bg-primary-600/20"></div>
</section>
