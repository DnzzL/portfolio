---
import social from "@config/social";

const socialItems = social.networks;
---

<section class="relative min-h-[90vh] flex items-center bg-grid noise-texture overflow-hidden">
  <!-- Technical grid overlay -->
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-[#1a1a2e]"></div>
  
  <!-- Corner accents -->
  <div class="absolute top-0 left-0 w-32 h-px bg-gradient-to-r from-[#d69e2e] to-transparent"></div>
  <div class="absolute top-0 left-0 w-px h-32 bg-gradient-to-b from-[#d69e2e] to-transparent"></div>
  <div class="absolute top-0 right-0 w-32 h-px bg-gradient-to-l from-[#d69e2e] to-transparent"></div>
  <div class="absolute top-0 right-0 w-px h-32 bg-gradient-to-b from-[#d69e2e] to-transparent"></div>
  
  <div class="relative w-full max-w-6xl mx-auto px-6 sm:px-8 lg:px-12 py-24">
    <!-- Status indicator -->
    <div class="animate-fade-in-up mb-12">
      <div class="inline-flex items-center gap-3 px-4 py-2 border border-[rgba(214,158,46,0.3)] bg-[rgba(214,158,46,0.05)]">
        <span class="w-2 h-2 bg-[#d69e2e] animate-pulse"></span>
        <span class="text-xs uppercase tracking-[0.2em] text-[#718096]">Available for work</span>
      </div>
    </div>
    
    <!-- Main heading -->
    <div class="animate-fade-in-up" style="animation-delay: 0.1s">
      <div class="flex items-baseline gap-4 mb-4">
        <span class="text-[#4a5568] text-sm">~/</span>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-medium tracking-tight text-[#f7f7f5] cursor-blink">
          Thomas Legrand
        </h1>
      </div>
      
      <div class="flex items-baseline gap-4 ml-0 sm:ml-8">
        <span class="text-[#4a5568] text-sm">$</span>
        <p class="text-lg sm:text-xl text-[#718096] max-w-2xl">
          Software engineer building products at the intersection of AI and web development.
          Former data scientist turned full-stack developer.
        </p>
      </div>
    </div>
    
    <!-- Location / context -->
    <div class="animate-fade-in-up mt-8 ml-0 sm:ml-8" style="animation-delay: 0.2s">
      <div class="flex items-center gap-2 text-sm text-[#4a5568]">
        <span class="w-4 h-px bg-[#4a5568]"></span>
        <span>Paris, France</span>
        <span class="text-[#d69e2e]">•</span>
        <span>Vue / Nuxt / TypeScript / AI</span>
      </div>
    </div>
    
    <!-- CTA Section -->
    <div class="animate-fade-in-up mt-16 ml-0 sm:ml-8" style="animation-delay: 0.3s">
      <div class="flex flex-col sm:flex-row gap-6 items-start sm:items-center">
        <a 
          href="/projects" 
          class="group inline-flex items-center gap-3 px-6 py-3 border border-[rgba(255,255,255,0.1)] hover:border-[#d69e2e] transition-colors duration-200"
        >
          <span class="text-sm uppercase tracking-[0.15em] text-[#f7f7f5]">View projects</span>
          <svg 
            class="w-4 h-4 text-[#d69e2e] transform transition-transform duration-200 group-hover:translate-x-1" 
            fill="none" 
            stroke="currentColor" 
            viewBox="0 0 24 24"
          >
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
        
        <a 
          href="/blog" 
          class="text-sm text-[#718096] hover:text-[#f7f7f5] transition-colors duration-200 flex items-center gap-2"
        >
          <span>Read the blog</span>
          <span class="text-[#4a5568]">→</span>
        </a>
      </div>
    </div>
    
    <!-- Social links - minimal -->
    <div class="animate-fade-in-up mt-20 ml-0 sm:ml-8" style="animation-delay: 0.4s">
      <div class="flex items-center gap-6">
        {socialItems?.map((item) => (
          <a 
            href={item.url} 
            target="_blank" 
            rel="noopener noreferrer" 
            class="text-[#4a5568] hover:text-[#d69e2e] transition-colors duration-200"
            aria-label={item.name}
          >
            <figure class="w-5 h-5">
              <Fragment set:html={item.svg} />
            </figure>
          </a>
        ))}
      </div>
    </div>
  </div>
  
  <!-- Bottom accent line -->
  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[rgba(255,255,255,0.1)] to-transparent"></div>
</section>
