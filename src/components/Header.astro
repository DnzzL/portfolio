---
import config from '@config/config.json';
import menu from '@config/menu.json';
import HamburgerIcon from '@icons/HamburgerIcon.astro';

export interface NavigationLink {
  name: string;
  url: string;
}

const { main }: { main: NavigationLink[] } = menu;
---

<header class="fixed inset-x-0 top-0 z-50 bg-[#1a1a2e]/95 backdrop-blur-sm border-b border-[rgba(255,255,255,0.06)] print:hidden">
  <nav class="mx-auto max-w-6xl px-6 sm:px-8 lg:px-12" aria-label="Global">
    <div class="flex h-16 items-center justify-between">
      <!-- Logo -->
      <div class="flex items-center">
        <a href="/" class="flex items-center gap-3 group">
          <span class="text-xs text-[#4a5568]">$</span>
          <span class="text-sm font-medium text-[#f7f7f5] group-hover:text-[#d69e2e] transition-colors duration-200">
            {config.site.title}
          </span>
        </a>
      </div>
      
      <!-- Desktop navigation -->
      <div class="hidden lg:flex lg:items-center lg:gap-8">
        {main?.map((menu) => (
          <a
            href={menu?.url}
            class="text-sm text-[#718096] hover:text-[#f7f7f5] transition-colors duration-200"
          >
            {menu?.name}
          </a>
        ))}
      </div>
      
      <!-- Right side -->
      <div class="flex items-center gap-4">
        <!-- Mobile menu button -->
        <div class="flex lg:hidden">
          <button
            type="button"
            class="text-[#718096] hover:text-[#f7f7f5] transition-colors duration-200 p-2"
            onclick="document.getElementById('mobile-menu').classList.toggle('hidden')"
          >
            <span class="sr-only">Open main menu</span>
            <HamburgerIcon />
          </button>
        </div>
      </div>
    </div>
  </nav>
  
  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-[rgba(255,255,255,0.06)]">
    <div class="bg-[#1a1a2e]">
      <div class="space-y-px px-6 py-4">
        {main?.map((menu) => (
          <a
            href={menu?.url}
            class="block py-3 text-sm text-[#718096] hover:text-[#f7f7f5] transition-colors duration-200 border-b border-[rgba(255,255,255,0.06)] last:border-0"
            onclick="document.getElementById('mobile-menu').classList.add('hidden')"
          >
            {menu?.name}
          </a>
        ))}
      </div>
    </div>
  </div>
</header>
