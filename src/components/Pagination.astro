---
import NextIcon from '@icons/NextIcon.astro';
import PrevIcon from '@icons/PrevIcon.astro';

const { length, currentPage, firstUrl, prevUrl, nextUrl } = Astro.props;
const paginationList = Array.from({ length }, (_, i) => i + 1);
---

<nav class="mt-16">
  <ol class="flex justify-center items-center gap-2 text-sm">
    {
      prevUrl ? (
        <li>
          <a
            href={prevUrl}
            class="inline-flex h-10 w-10 items-center justify-center border border-[rgba(255,255,255,0.1)] text-[#718096] hover:border-[#d69e2e] hover:text-[#f7f7f5] transition-colors duration-200"
          >
            <span class="sr-only">Prev Page</span>
            <PrevIcon />
          </a>
        </li>
      ) : null
    }
    {
      paginationList?.map((num) => (
        <li>
          <a
            href={`${firstUrl}${num == 1 ? '' : '' + num}`}
            class={`block h-10 w-10 border text-center leading-10 transition-colors duration-200 ${
              currentPage == num 
                ? 'border-[#d69e2e] bg-[rgba(214,158,46,0.1)] text-[#d69e2e]' 
                : 'border-[rgba(255,255,255,0.1)] text-[#718096] hover:border-[#d69e2e] hover:text-[#f7f7f5]'
            }`}
          >
            {String(num).padStart(2, '0')}
          </a>
        </li>
      ))
    }
    {
      nextUrl ? (
        <li>
          <a
            href={nextUrl}
            class="inline-flex h-10 w-10 items-center justify-center border border-[rgba(255,255,255,0.1)] text-[#718096] hover:border-[#d69e2e] hover:text-[#f7f7f5] transition-colors duration-200"
          >
            <span class="sr-only">Next Page</span>
            <NextIcon />
          </a>
        </li>
      ) : null
    }
  </ol>
</nav>
