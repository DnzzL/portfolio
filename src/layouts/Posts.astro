---
import FormattedDate from '@components/FormattedDate.astro';
import config from '@config/config.json';
import { slugify } from '@utils/slug';

const { posts } = Astro.props;

type PostType = {
  id: string;
  slug: string;
  body: string;
  collection: string;
  data: {
    title: string;
    description: string;
    heroImage: string;
    pubDate: Date;
    categories: string[];
    tags: string[];
    autors: string[];
  };
};
---

<div class="space-y-4">
  {posts?.slice(0, config.site.pageSize).map((post: PostType, index: number) => (
    <article class="group bg-[#1a1a2e] border border-[rgba(255,255,255,0.06)] p-6 sm:p-8 card-hover flex flex-col sm:flex-row sm:items-center gap-4 sm:gap-8">
      <!-- Number -->
      <div class="hidden sm:block w-8 shrink-0">
        <span class="text-xs text-[#4a5568] font-mono">{String(index + 1).padStart(2, '0')}</span>
      </div>
      
      <!-- Date -->
      <div class="sm:w-28 shrink-0">
        <span class="text-xs text-[#4a5568] font-mono">
          <FormattedDate date={post.data.pubDate} />
        </span>
      </div>
      
      <!-- Content -->
      <div class="flex-1 min-w-0">
        <div class="flex flex-wrap items-center gap-3 mb-2">
          {post.data.categories.slice(0, 1).map((item) => (
            <a
              href={`/categories/${slugify(item)}`}
              class="text-xs uppercase tracking-[0.1em] text-[#d69e2e] hover:text-[#ecc94b] transition-colors duration-200"
            >
              {item}
            </a>
          ))}
        </div>
        
        <h2 class="text-lg font-medium text-[#f7f7f5] group-hover:text-[#d69e2e] transition-colors duration-200">
          <a href={`/blog/${post.slug}/`}>
            {post.data.title}
          </a>
        </h2>
        
        <p class="text-sm text-[#718096] mt-2 line-clamp-1">
          {post.data.description}
        </p>
      </div>
      
      <!-- Arrow -->
      <div class="hidden sm:block shrink-0">
        <svg 
          class="w-5 h-5 text-[#4a5568] group-hover:text-[#d69e2e] transform group-hover:translate-x-1 transition-all duration-200" 
          fill="none" 
          stroke="currentColor" 
          viewBox="0 0 24 24"
        >
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </div>
    </article>
  ))}
</div>
