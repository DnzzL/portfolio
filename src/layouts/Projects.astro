---
import FormattedDate from '@components/FormattedDate.astro';
import config from '@config/config.json';
import { slugify } from '@utils/slug';

const { projects } = Astro.props;

type ProjectType = {
  id: string;
  slug: string;
  body: string;
  collection: string;
  data: {
    title: string;
    heroImage: string;
    github: string;
    pubDate: Date;
    categories: string[];
    tags: string[];
    autors: string[];
  };
};
---

<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
  {projects?.slice(0, config.site.pageSize).map((project: ProjectType, index: number) => (
    <article class="group bg-[#252540] border border-[rgba(255,255,255,0.06)] p-8 card-hover">
      <!-- Top row: number and date -->
      <div class="flex items-baseline justify-between mb-6">
        <span class="text-xs text-[#4a5568] font-mono">{String(index + 1).padStart(2, '0')}</span>
        <span class="text-xs text-[#4a5568]">
          <FormattedDate date={project.data.pubDate} />
        </span>
      </div>
      
      <!-- Category -->
      <div class="mb-4">
        {project.data.categories.slice(0, 1).map((item) => (
          <a
            href={`/categories/${slugify(item)}`}
            class="text-xs uppercase tracking-[0.15em] text-[#d69e2e] hover:text-[#ecc94b] transition-colors duration-200"
          >
            {item}
          </a>
        ))}
      </div>
      
      <!-- Title -->
      <h2 class="text-xl font-medium text-[#f7f7f5] mb-3 group-hover:text-[#d69e2e] transition-colors duration-200">
        <a href={`/projects/${project.slug}/`}>
          {project.data.title}
        </a>
      </h2>
      
      <!-- Link -->
      <a 
        href={`/projects/${project.slug}/`} 
        class="inline-flex items-center gap-2 text-sm text-[#4a5568] group-hover:text-[#f7f7f5] transition-colors duration-200"
      >
        <span class="w-4 h-px bg-current"></span>
        <span>View project</span>
      </a>
    </article>
  ))}
</div>
