---
import FormattedDate from '@components/FormattedDate.astro';
import config from '@config/config.json';
import Base from '@layouts/Base.astro';
import { slugify } from '@utils/slug';
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, heroImage, categories, tags } = Astro.props;
---

<Base meta_title={title} description={description} image={heroImage} minimalist>
  <article class="relative py-16 sm:py-24 noise-texture">
    <div class="max-w-4xl mx-auto px-6 sm:px-8 lg:px-12">
      <!-- Breadcrumb -->
      <div class="mb-12">
        <a href="/blog" class="text-sm text-[#4a5568] hover:text-[#d69e2e] transition-colors duration-200 flex items-center gap-2">
          <span>←</span>
          <span>Back to articles</span>
        </a>
      </div>
      
      <!-- Article header -->
      <header class="mb-12 border-b border-[rgba(255,255,255,0.06)] pb-12">
        <!-- Meta -->
        <div class="flex flex-wrap items-center gap-4 mb-6 text-xs uppercase tracking-[0.1em] text-[#4a5568]">
          <span class="text-[#d69e2e]">
            <FormattedDate date={pubDate} />
          </span>
          {categories?.map((category) => (
            <span>•</span>
            <a 
              href={`/categories/${slugify(category)}`} 
              class="hover:text-[#d69e2e] transition-colors duration-200"
            >
              {category}
            </a>
          ))}
        </div>
        
        <!-- Title -->
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-medium text-[#f7f7f5] leading-tight">
          {title}
        </h1>
        
        <!-- Description -->
        {description && (
          <p class="mt-6 text-lg text-[#718096] leading-relaxed">
            {description}
          </p>
        )}
      </header>
      
      <!-- Hero image -->
      {heroImage && (
        <div class="mb-12 border border-[rgba(255,255,255,0.06)]">
          <figure>
            <Image
              src={heroImage}
              alt={title}
              width={960}
              height={480}
              decoding="async"
              loading="lazy"
              class="w-full"
            />
          </figure>
        </div>
      )}
      
      <!-- Article content -->
      <div class="prose-industrial prose prose-invert max-w-none">
        <slot />
      </div>
      
      <!-- Tags -->
      {tags && tags.length > 0 && (
        <div class="mt-16 pt-8 border-t border-[rgba(255,255,255,0.06)]">
          <div class="flex flex-wrap items-center gap-3">
            <span class="text-xs uppercase tracking-[0.1em] text-[#4a5568]">Tags:</span>
            {tags?.map((tag) => (
              <a
                href={`/tags/${slugify(tag)}`}
                class="text-xs text-[#718096] hover:text-[#d69e2e] transition-colors duration-200"
              >
                #{tag}
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </article>
</Base>
