---
import Base from '@layouts/Base.astro';
import { getTaxonomy } from '@utils/getAllTags';

const blogCategories = await getTaxonomy('blog', 'categories');
const projectCategories = await getTaxonomy('project', 'categories');
---

<Base meta_title="Categories">
  <div class="relative py-24 sm:py-32 noise-texture">
    <div class="max-w-6xl mx-auto px-6 sm:px-8 lg:px-12">
      <!-- Section header -->
      <div class="mb-16 border-b border-[rgba(255,255,255,0.06)] pb-6">
        <span class="text-xs uppercase tracking-[0.2em] text-[#4a5568] mb-2 block">~/categories</span>
        <h1 class="text-3xl sm:text-4xl font-medium text-[#f7f7f5]">All Categories</h1>
      </div>
      
      <!-- Categories grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {[...blogCategories, ...projectCategories].map((category, index) => (
          <a
            href={`/categories/${category.slug}`}
            class="group bg-[#252540] border border-[rgba(255,255,255,0.06)] p-6 card-hover flex items-center justify-between"
          >
            <div>
              <span class="text-xs text-[#4a5568] font-mono block mb-2">{String(index + 1).padStart(2, '0')}</span>
              <span class="text-[#f7f7f5] group-hover:text-[#d69e2e] transition-colors duration-200 capitalize">
                {category.name}
              </span>
            </div>
            <svg 
              class="w-5 h-5 text-[#4a5568] group-hover:text-[#d69e2e] transform group-hover:translate-x-1 transition-all duration-200" 
              fill="none" 
              stroke="currentColor" 
              viewBox="0 0 24 24"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        ))}
      </div>
    </div>
  </div>
</Base>
