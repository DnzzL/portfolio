---
import { getCollection } from "astro:content";
import Base from "@layouts/Base.astro";
import Hero from "@components/Hero.astro";
import { slugify } from '@utils/slug';
import FormattedDate from '@components/FormattedDate.astro';

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const projects = (await getCollection("project")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

type PostType = {
  id: string;
  slug: string;
  body: string;
  collection: string;
  data: {
    title: string;
    description: string;
    heroImage: string;
    pubDate: Date;
    categories: string[];
    tags: string[];
    autors: string[];
  };
};
---

<Base>
  <Hero />
  
  <!-- Featured Projects Section -->
  <section class="relative py-24 sm:py-32 noise-texture">
    <div class="max-w-6xl mx-auto px-6 sm:px-8 lg:px-12">
      <!-- Section header -->
      <div class="flex items-baseline justify-between mb-16 border-b border-[rgba(255,255,255,0.06)] pb-6">
        <div>
          <span class="text-xs uppercase tracking-[0.2em] text-[#4a5568] mb-2 block">01</span>
          <h2 class="text-2xl sm:text-3xl font-medium text-[#f7f7f5]">Projects</h2>
        </div>
        <a href="/projects" class="text-sm text-[#718096] hover:text-[#d69e2e] transition-colors duration-200 flex items-center gap-2">
          <span>View all</span>
          <span>→</span>
        </a>
      </div>
      
      <!-- Projects grid - improved layout -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {projects?.slice(0, 4).map((project: PostType, index) => (
          <article class="group bg-[#252540] border border-[rgba(255,255,255,0.06)] p-8 card-hover">
            <!-- Top row: number and date -->
            <div class="flex items-baseline justify-between mb-6">
              <span class="text-xs text-[#4a5568] font-mono">0{index + 1}</span>
              <span class="text-xs text-[#4a5568]">
                <FormattedDate date={project.data.pubDate} />
              </span>
            </div>
            
            <!-- Category -->
            <div class="mb-4">
              {project.data.categories.slice(0, 1).map((item) => (
                <span class="text-xs uppercase tracking-[0.15em] text-[#d69e2e]">
                  {item}
                </span>
              ))}
            </div>
            
            <!-- Title -->
            <h3 class="text-xl font-medium text-[#f7f7f5] mb-3 group-hover:text-[#d69e2e] transition-colors duration-200">
              <a href={`/projects/${project.slug}/`}>
                {project.data.title}
              </a>
            </h3>
            
            <!-- Description -->
            <p class="text-sm text-[#718096] leading-relaxed mb-6 line-clamp-2">
              {project.data.description}
            </p>
            
            <!-- Link -->
            <a 
              href={`/projects/${project.slug}/`} 
              class="inline-flex items-center gap-2 text-sm text-[#4a5568] group-hover:text-[#f7f7f5] transition-colors duration-200"
            >
              <span class="w-4 h-px bg-current"></span>
              <span>Read case study</span>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Latest Articles Section -->
  <section class="relative py-24 sm:py-32 bg-[#252540] noise-texture">
    <div class="max-w-6xl mx-auto px-6 sm:px-8 lg:px-12">
      <!-- Section header -->
      <div class="flex items-baseline justify-between mb-16 border-b border-[rgba(255,255,255,0.06)] pb-6">
        <div>
          <span class="text-xs uppercase tracking-[0.2em] text-[#4a5568] mb-2 block">02</span>
          <h2 class="text-2xl sm:text-3xl font-medium text-[#f7f7f5]">Writing</h2>
        </div>
        <a href="/blog" class="text-sm text-[#718096] hover:text-[#d69e2e] transition-colors duration-200 flex items-center gap-2">
          <span>All articles</span>
          <span>→</span>
        </a>
      </div>
      
      <!-- Articles list -->
      <div class="space-y-4">
        {posts?.slice(0, 5).map((post: PostType) => (
          <article class="group bg-[#1a1a2e] border border-[rgba(255,255,255,0.06)] p-6 sm:p-8 card-hover flex flex-col sm:flex-row sm:items-center gap-4 sm:gap-8">
            <!-- Date -->
            <div class="sm:w-32 shrink-0">
              <span class="text-xs text-[#4a5568] font-mono">
                <FormattedDate date={post.data.pubDate} />
              </span>
            </div>
            
            <!-- Content -->
            <div class="flex-1 min-w-0">
              <div class="flex flex-wrap items-center gap-3 mb-2">
                {post.data.categories.slice(0, 1).map((item) => (
                  <span class="text-xs uppercase tracking-[0.1em] text-[#d69e2e]">
                    {item}
                  </span>
                ))}
              </div>
              
              <h3 class="text-lg font-medium text-[#f7f7f5] group-hover:text-[#d69e2e] transition-colors duration-200">
                <a href={`/blog/${post.slug}/`}>
                  {post.data.title}
                </a>
              </h3>
              
              <p class="text-sm text-[#718096] mt-2 line-clamp-1">
                {post.data.description}
              </p>
            </div>
            
            <!-- Arrow -->
            <div class="hidden sm:block shrink-0">
              <svg 
                class="w-5 h-5 text-[#4a5568] group-hover:text-[#d69e2e] transform group-hover:translate-x-1 transition-all duration-200" 
                fill="none" 
                stroke="currentColor" 
                viewBox="0 0 24 24"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- About/Contact Section -->
  <section class="relative py-24 sm:py-32 noise-texture">
    <div class="max-w-6xl mx-auto px-6 sm:px-8 lg:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">
        <!-- Left column -->
        <div>
          <span class="text-xs uppercase tracking-[0.2em] text-[#4a5568] mb-4 block">03</span>
          <h2 class="text-2xl sm:text-3xl font-medium text-[#f7f7f5] mb-6">
            About
          </h2>
          <div class="prose-industrial text-[#718096]">
            <p>
              I'm a software engineer with a background in data science, focused on building 
              practical products that leverage AI and modern web technologies.
            </p>
            <p>
              After years of research and experimentation in the data world, I transitioned 
              to full-stack development to create tangible solutions. I believe the future 
              lies in the thoughtful integration of AI into everyday tools.
            </p>
            <p class="text-[#f7f7f5]">
              Currently based in Paris, working with Vue, Nuxt, TypeScript, and AI APIs.
            </p>
          </div>
        </div>
        
        <!-- Right column - Contact -->
        <div>
          <span class="text-xs uppercase tracking-[0.2em] text-[#4a5568] mb-4 block">04</span>
          <h2 class="text-2xl sm:text-3xl font-medium text-[#f7f7f5] mb-6">
            Contact
          </h2>
          <p class="text-[#718096] mb-8">
            Open to interesting projects and conversations. Reach out if you want to collaborate 
            or just chat about technology.
          </p>
          
          <a 
            href="mailto:contact@example.com" 
            class="inline-flex items-center gap-3 px-6 py-3 border border-[rgba(255,255,255,0.1)] hover:border-[#d69e2e] transition-colors duration-200"
          >
            <span class="text-sm uppercase tracking-[0.15em] text-[#f7f7f5]">Get in touch</span>
            <span class="text-[#d69e2e]">→</span>
          </a>
        </div>
      </div>
    </div>
    
    <!-- Bottom grid line -->
    <div class="absolute bottom-0 left-0 right-0 h-px bg-[rgba(255,255,255,0.06)]"></div>
  </section>
</Base>
