---
import LeftArrowIcon from "@components/icons/LeftArrowIcon.astro";
import Base from "@layouts/Base.astro";
---

<Base meta_title="404 - Page Not Found" minimalist>
  <div class="relative min-h-[80vh] flex items-center justify-center noise-texture">
    <div class="max-w-6xl mx-auto px-6 sm:px-8 lg:px-12 text-center">
      <!-- Error code -->
      <div class="mb-8">
        <span class="text-8xl sm:text-9xl font-medium text-[#4a5568]">404</span>
      </div>
      
      <!-- Message -->
      <h1 class="text-2xl sm:text-3xl font-medium text-[#f7f7f5] mb-4">
        Page not found
      </h1>
      
      <p class="text-[#718096] mb-12 max-w-md mx-auto">
        The page you're looking for doesn't exist or has been moved.
      </p>
      
      <!-- Back link -->
      <a
        href="/"
        class="inline-flex items-center gap-3 px-6 py-3 border border-[rgba(255,255,255,0.1)] hover:border-[#d69e2e] transition-colors duration-200"
      >
        <LeftArrowIcon />
        <span class="text-sm uppercase tracking-[0.15em] text-[#f7f7f5]">Back home</span>
      </a>
    </div>
  </div>
</Base>
